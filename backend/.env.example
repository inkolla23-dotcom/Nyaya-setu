# =============================================
# Nyaya Setu Backend — Environment Variables
# Copy this file to .env and fill in values.
# NEVER commit the .env file with real secrets.
# =============================================

# --- Database (Aiven MySQL) ---
DB_HOST=your-aiven-host.aivencloud.com
DB_PORT=your-aiven-port
DB_USER=your-aiven-user
DB_PASSWORD=your-aiven-password
DB_NAME=nyaya_setu

# --- SSL (set DB_SSL=true for Aiven / remote MySQL) ---
DB_SSL=true
# DB_SSL_CA=-----BEGIN CERTIFICATE-----...   # Optional: paste full CA cert content

# --- App ---
PORT=5000
JWT_SECRET=change_me_to_a_long_random_string

# --- CORS (set to your Vercel frontend URL in production) ---
FRONTEND_URL=https://your-frontend.vercel.app

# --- AI Providers ---
AI_PROVIDER=gemini
GEMINI_API_KEY=your-gemini-api-key
AI_MODEL=gemini-2.5-flash

# --- Groq fallback ---
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# --- OpenAI (if used) ---
OPENAI_API_KEY=mock_key
OPENAI_BASE_URL=https://api.openai.com/v1
